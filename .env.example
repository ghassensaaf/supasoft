# Contact form delivery via Resend (https://resend.com) — free tier is
# 3,000 emails/month. Create an API key and set it in Vercel:
#   vercel env add RESEND_API_KEY
RESEND_API_KEY=

# Where contact-form submissions are delivered (default: contact@supasoft.dev)
CONTACT_TO_EMAIL=

# Sender address. Must be onboarding@resend.dev until supasoft.dev is
# verified in Resend; after verification use e.g.
#   Supasoft Website <contact@supasoft.dev>
CONTACT_FROM_EMAIL=
